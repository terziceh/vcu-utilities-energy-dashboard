          <datasource-dependencies datasource='federated.0vqyoaq0engmzc14hxwj816uv37k'>
            <column caption='Building Name' datatype='string' name='[Building_Name]' role='dimension' type='nominal' />
            <column caption='Current Year Energy Cost' datatype='real' name='[Calculation_2327438175379457]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF [FY] = [Parameters].[Parameter 1] THEN [Calculation_2507208069632000] END' />
            </column>
            <column caption='Previous Year Energy Cost' datatype='real' name='[Calculation_2327438178574338]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF INT(RIGHT([FY],2)) = INT(RIGHT([Parameters].[Parameter 1],2)) - 1&#13;&#10;THEN [Calculation_2507208069632000]&#13;&#10;END' />
            </column>
            <column caption='Filter on FY Parameter' datatype='boolean' name='[Calculation_2327438196006915]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='INT(RIGHT([FY],2)) = INT(RIGHT([Parameters].[Parameter 1], 2))&#13;&#10;&#13;&#10;OR&#13;&#10;&#13;&#10;INT(RIGHT([FY],2)) = INT(RIGHT([Parameters].[Parameter 1], 2)) - 1' />
            </column>
            <column caption='Difference in Cost' datatype='real' name='[Calculation_2431067554201611]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='AVG([Calculation_2327438175379457]) - AVG([Calculation_2327438178574338])' />
            </column>
            <column caption='Energy_Cost' datatype='real' name='[Calculation_2507208069632000]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='[Total_Usage]/[Consumption]' />
            </column>
            <column caption='Fiscal Month' datatype='string' name='[Calculation_2507208073076737]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='CASE [Reporting_Month]&#13;&#10;&#13;&#10;WHEN 1 THEN &quot;Jul&quot;&#13;&#10;WHEN 2 THEN &quot;Aug&quot;&#13;&#10;WHEN 3 THEN &quot;Sep&quot;&#13;&#10;WHEN 4 THEN &quot;Oct&quot;&#13;&#10;WHEN 5 THEN &quot;Nov&quot;&#13;&#10;WHEN 6 THEN &quot;Dec&quot;&#13;&#10;WHEN 7 THEN &quot;Jan&quot;&#13;&#10;WHEN 8 THEN &quot;Feb&quot;&#13;&#10;WHEN 9 THEN &quot;Mar&quot;&#13;&#10;WHEN 10 THEN &quot;Apr&quot;&#13;&#10;WHEN 11 THEN &quot;May&quot;&#13;&#10;WHEN 12 THEN &quot;Jun&quot;&#13;&#10;&#13;&#10;END' />
            </column>
            <column datatype='real' name='[Consumption]' role='measure' type='quantitative' />
            <column datatype='string' name='[FY]' role='dimension' type='nominal' />
            <column caption='Reporting Month' datatype='integer' name='[Reporting_Month]' role='dimension' type='quantitative' />
            <column caption='Total Usage' datatype='real' name='[Total_Usage]' role='measure' type='quantitative' />
