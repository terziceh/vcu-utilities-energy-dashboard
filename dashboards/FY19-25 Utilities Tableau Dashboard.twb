    <worksheet name='Monthly Spend vs Consumption'>
      <table>
        <view>
          <datasources>
            <datasource caption='Cleaned_Utility_Data_Tableau' name='federated.0vqyoaq0engmzc14hxwj816uv37k' />
            <datasource name='Parameters' />
          </datasources>
          <datasource-dependencies datasource='Parameters'>
            <column alias='FY25' caption='p.Selected FY' datatype='string' datatype-customized='true' name='[Parameter 1]' param-domain-type='list' role='measure' type='nominal' value='&quot;FY25&quot;'>
              <calculation class='tableau' formula='&quot;FY25&quot;' />
              <aliases>
                <alias key='&quot;FY18&quot;' value='FY18' />
                <alias key='&quot;FY19&quot;' value='FY19' />
                <alias key='&quot;FY20&quot;' value='FY20' />
                <alias key='&quot;FY21&quot;' value='FY21' />
                <alias key='&quot;FY22&quot;' value='FY22' />
                <alias key='&quot;FY23&quot;' value='FY23' />
                <alias key='&quot;FY24&quot;' value='FY24' />
                <alias key='&quot;FY25&quot;' value='FY25' />
              </aliases>
            </column>
          </datasource-dependencies>
          <datasource-dependencies datasource='federated.0vqyoaq0engmzc14hxwj816uv37k'>
            <column caption='Amount Due' datatype='real' name='[Amount_Due]' role='measure' type='quantitative' />
            <column caption='Building Name' datatype='string' name='[Building_Name]' role='dimension' type='nominal' />
            <column caption='Filter on FY Parameter' datatype='boolean' name='[Calculation_2327438196006915]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='INT(RIGHT([FY],2)) = INT(RIGHT([Parameters].[Parameter 1], 2))&#13;&#10;&#13;&#10;OR&#13;&#10;&#13;&#10;INT(RIGHT([FY],2)) = INT(RIGHT([Parameters].[Parameter 1], 2)) - 1' />
            </column>
            <column caption='Label Spend' datatype='string' name='[Calculation_2431067505205248]' role='measure' type='nominal'>
              <calculation class='tableau' formula='&quot;$&quot; + STR(ROUND(SUM([Amount_Due])/1000000, 1)) + &quot;M&quot;' />
            </column>
            <column caption='Spend Highlight' datatype='string' name='[Calculation_2431067506896897]' role='measure' type='nominal'>
              <calculation class='tableau' formula='IF SUM([Amount_Due])  = WINDOW_MAX(SUM([Amount_Due])) THEN &quot;Max&quot;&#13;&#10;ELSEIF SUM([Amount_Due])  = WINDOW_MIN(SUM([Amount_Due])) THEN &quot;Min&quot;&#13;&#10;ELSE &quot;Normal&quot;&#13;&#10;END'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column caption='Consumption Highlight' datatype='string' name='[Calculation_2431067516989448]' role='measure' type='nominal'>
              <calculation class='tableau' formula='IF SUM([Consumption]) = WINDOW_MAX(SUM([Consumption])) THEN &quot;Max&quot;&#13;&#10;ELSEIF SUM([Consumption]) = WINDOW_MIN(SUM([Consumption])) THEN &quot;Min&quot;&#13;&#10;ELSE &quot;Normal&quot;&#13;&#10;END'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column caption='Fiscal Month' datatype='string' name='[Calculation_2507208073076737]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='CASE [Reporting_Month]&#13;&#10;&#13;&#10;WHEN 1 THEN &quot;Jul&quot;&#13;&#10;WHEN 2 THEN &quot;Aug&quot;&#13;&#10;WHEN 3 THEN &quot;Sep&quot;&#13;&#10;WHEN 4 THEN &quot;Oct&quot;&#13;&#10;WHEN 5 THEN &quot;Nov&quot;&#13;&#10;WHEN 6 THEN &quot;Dec&quot;&#13;&#10;WHEN 7 THEN &quot;Jan&quot;&#13;&#10;WHEN 8 THEN &quot;Feb&quot;&#13;&#10;WHEN 9 THEN &quot;Mar&quot;&#13;&#10;WHEN 10 THEN &quot;Apr&quot;&#13;&#10;WHEN 11 THEN &quot;May&quot;&#13;&#10;WHEN 12 THEN &quot;Jun&quot;&#13;&#10;&#13;&#10;END' />
            </column>
            <column datatype='real' name='[Consumption]' role='measure' type='quantitative' />
